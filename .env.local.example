# Copie ce fichier en .env.local et remplis avec tes vraies valeurs
# (Supabase > Project Settings > API)

NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=ta-cle-anon-publique

# Clé secrète (service_role) — UNIQUEMENT pour les fonctionnalités admin.
# Ne jamais préfixer par NEXT_PUBLIC_, sinon elle serait visible du navigateur.
SUPABASE_SERVICE_ROLE_KEY=ta-cle-service-role-secrete

# Resend (envoi d'email) — https://resend.com > API Keys
RESEND_API_KEY=ta-cle-resend

# Adresse qui reçoit un email à chaque nouvelle inscription fournisseur
ADMIN_NOTIFICATION_EMAIL=adbensaid@gmail.com
